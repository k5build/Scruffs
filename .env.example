# ──────────────────────────────────────────
# Scruffs.ae – Environment Variables
# Copy this file to .env.local for local dev
# Set ALL of these in Vercel dashboard
# ──────────────────────────────────────────

# Database (SQLite local / PostgreSQL production)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Auth - generate: openssl rand -base64 32
JWT_SECRET="CHANGE-ME-TO-A-RANDOM-64-CHAR-STRING"
ADMIN_SECRET="scruffs2024"

# Twilio (SMS OTP + WhatsApp)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_VERIFY_SID="VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Business notifications WhatsApp
BUSINESS_NOTIFY_PHONE="+971501234567"

# Email via Resend (resend.com - free 100/day)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Scruffs <bookings@scruffs.ae>"

# App URL
NEXT_PUBLIC_APP_URL="https://scruffs.ae"
