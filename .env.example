# ==============================================
# SCRUFFS.AE – Environment Variables
# ==============================================
# Copy this file to .env.local and fill in values

# --- Database (PostgreSQL – use Neon.tech free tier) ---
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Admin Dashboard ---
ADMIN_PASSWORD="your-secure-admin-password"
ADMIN_SECRET="your-jwt-secret-32chars-minimum"

# --- App URL ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Optional: Email notifications (Resend.com) ---
RESEND_API_KEY=""
FROM_EMAIL="bookings@scruffs.ae"

# --- Optional: WhatsApp Business API ---
WHATSAPP_BUSINESS_NUMBER="+971XXXXXXXXX"

# --- Optional: Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
